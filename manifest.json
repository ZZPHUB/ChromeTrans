{
  "manifest_version": 3,
  "name": "DeepSeek 划词翻译",
  "version": "1.1",
  "description": "选中文字，点击附近图标即可翻译",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeepSeek 划词翻译"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
